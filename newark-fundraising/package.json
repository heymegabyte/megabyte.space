{
  "name": "newark-fundraising-automation",
  "version": "1.0.0",
  "description": "Fundraising automation for St. John's Soup Kitchen - Newark, NJ",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "preview": "ts-node src/index.ts --preview",
    "dry-run": "ts-node src/index.ts --dry-run",
    "send-test": "ts-node src/index.ts --send-test",
    "send-all": "ts-node src/index.ts --send-all",
    "test": "jest --forceExit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "lob": "^6.6.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "dotenv": "^16.4.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
